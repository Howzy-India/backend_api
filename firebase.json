{
  "functions": {
    "source": ".",
    "runtime": "nodejs22",
    "secretEnvironmentVariables": [
      { "key": "CLOUD_SQL_INSTANCE" },
      { "key": "DB_NAME" },
      { "key": "DB_USER" },
      { "key": "BACKUP_SHEET_ID" }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules",
    "bucket": "howzy-api.firebasestorage.app"
  },
  "dataconnect": {
    "source": "dataconnect"
  },
  "emulators": {
    "dataconnect": {
      "dataDir": "dataconnect/.dataconnect/pgliteData"
    }
  }
}
