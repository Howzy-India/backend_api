rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ─────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function role() {
      return request.auth.token.role;
    }

    function isSuperAdmin() {
      return isSignedIn() && role() == 'super_admin';
    }

    function isAdmin() {
      return isSignedIn() && (role() == 'admin' || role() == 'super_admin');
    }

    function isAgent() {
      return isSignedIn() && role() == 'agent';
    }

    function isHowzerEmployee() {
      return isSignedIn() && role() == 'howzer_employee';
    }

    function isClient() {
      return isSignedIn() && role() == 'client';
    }

    function isOwner(email) {
      return isSignedIn() && request.auth.token.email == email;
    }

    // ── Users ────────────────────────────────────────────────────────
    match /users/{userId} {
      // Any signed-in user can read their own profile (needed for role sync)
      allow read: if isSuperAdmin()
        || (isSignedIn() && request.auth.uid == userId);
      // Users can update their own demographics; only super_admin can change role/status
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSuperAdmin()
        || (isSignedIn() && request.auth.uid == userId
            && !request.resource.data.diff(resource.data).affectedKeys()
               .hasAny(['role', 'status']));
      allow delete: if isSuperAdmin();
    }

    // ── Projects ─────────────────────────────────────────────────────
    match /projects/{projectId} {
      allow read: if true; // Public read
      allow create, update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    // ── Leads ────────────────────────────────────────────────────────
    match /leads/{leadId} {
      allow read: if isAdmin() || isAgent();
      allow create: if isSignedIn();
      allow update: if isAdmin() || isAgent();
      allow delete: if isSuperAdmin();
    }

    // ── Bookings / Earnings ──────────────────────────────────────────
    match /bookings/{bookingId} {
      allow read: if isAdmin() || isAgent();
      allow write: if isAdmin();
    }

    // ── Submissions ──────────────────────────────────────────────────
    match /submissions/{submissionId} {
      allow read: if isAdmin()
        || (isHowzerEmployee() && resource.data.email == request.auth.token.email)
        || (isClient() && resource.data.email == request.auth.token.email);
      allow create: if isSignedIn();
      allow update: if isAdmin()
        || (isHowzerEmployee() && resource.data.email == request.auth.token.email
            && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['details', 'updated_at']));
      allow delete: if isSuperAdmin();
    }

    // ── Enquiries ────────────────────────────────────────────────────
    match /enquiries/{enquiryId} {
      allow read: if isAdmin()
        || (isAgent() && resource.data.assigned_sales_id != null)
        || (isHowzerEmployee() && resource.data.assigned_partner_id != null)
        || (isClient() && resource.data.email == request.auth.token.email);
      allow create: if true; // Clients can create without auth
      allow update: if isAdmin()
        || (isHowzerEmployee() && resource.data.assigned_partner_id != null
            && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['status', 'updated_at']));
      allow delete: if isSuperAdmin();
    }

    // ── Enquiry Timeline ─────────────────────────────────────────────
    match /enquiry_timeline/{entryId} {
      allow read: if isAdmin() || isAgent() || isHowzerEmployee()
        || (isClient() && resource.data.created_by == request.auth.token.email);
      allow create: if isSignedIn();
      allow update, delete: if isSuperAdmin();
    }

    // ── Client Logins ────────────────────────────────────────────────
    match /client_logins/{loginId} {
      allow read: if isAdmin()
        || (isClient() && resource.data.email == request.auth.token.email);
      allow create: if true; // Public tracking
      allow update, delete: if isSuperAdmin();
    }

    // ── Builders ─────────────────────────────────────────────────────
    match /builders/{builderId} {
      allow read: if isAdmin();
      allow create: if isAdmin() || isHowzerEmployee();
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    // ── Approvals ────────────────────────────────────────────────────
    match /approvals/{approvalId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ── Client Profiles ──────────────────────────────────────────────
    match /client_profiles/{uid} {
      // A client can read/write only their own profile; admins can read all
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow delete: if isSuperAdmin();
    }

    // ── Audit Logs ───────────────────────────────────────────────────
    match /auditLogs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false; // Immutable
    }

    // ── Attendance ───────────────────────────────────────────────────
    match /attendance/{recordId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userEmail == request.auth.token.email);
      allow create: if isSignedIn()
        && (isAgent() || isHowzerEmployee() || isAdmin())
        && request.resource.data.userEmail == request.auth.token.email;
      allow update: if isAdmin()
        || (isSignedIn() && resource.data.userEmail == request.auth.token.email
            && (isAgent() || isHowzerEmployee()));
      allow delete: if isSuperAdmin();
    }

    // ── Location Logs ────────────────────────────────────────────────
    match /location_logs/{logId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userEmail == request.auth.token.email);
      allow create: if isSignedIn()
        && (isAgent() || isHowzerEmployee() || isAdmin())
        && request.resource.data.userEmail == request.auth.token.email;
      allow update, delete: if isSuperAdmin();
    }

    // ── Notifications ─────────────────────────────────────────────────
    // Written by admin/super_admin (broadcast); read by any signed-in user
    // matching the notification's room/recipient
    match /notifications/{notifId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }
  }
}
